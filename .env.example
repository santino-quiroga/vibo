# Vibo — variables de entorno (SDD sección 9.2)
#
# Copiá este archivo a `.env` y completá los valores. Ninguno tiene valor real acá.
# En Vercel se cargan en Settings -> Environment Variables, para Production y Preview.
#
# Las credenciales de cada agente (Airtable, Evolution API, token de integración)
# NO van acá: viven cifradas en Postgres, en la fila del Agente (SDD 3 y 7.1).

# --- Base de datos (Vercel Postgres / Neon) ------------------------------
# La que usa la app en runtime. Con Neon, es la URL del pooler (la que dice
# "-pooler"), que es la que aguanta muchas conexiones serverless.
DATABASE_URL=

# La que usan las migraciones del build: conexión DIRECTA, sin pooler.
# No es un capricho: `prisma migrate` toma un advisory lock de Postgres y eso
# falla a través del pooler de Neon. Si no la definís, se cae de vuelta a
# DATABASE_URL (alcanza en local, donde no hay pooler de por medio).
DIRECT_URL=

# Solo para desarrollo: `prisma migrate dev` necesita una base shadow aparte.
# En Vercel corre `prisma migrate deploy`, que no la usa. Dejala vacía en prod.
SHADOW_DATABASE_URL=

# --- Autenticación (NextAuth v5 / Auth.js) -------------------------------
# NOTA: el SDD 9.2 las nombra NEXTAUTH_SECRET y NEXTAUTH_URL, que es la
# nomenclatura de NextAuth v4. En v5 pasaron a llamarse AUTH_SECRET y AUTH_URL;
# son las mismas dos variables con otro nombre.
#
# Generar con: openssl rand -base64 32
AUTH_SECRET=

# URL pública de la app, ej. https://app.vibo.ar
# En Vercel se puede omitir: se deduce sola del deployment.
AUTH_URL=

# --- Cifrado de credenciales de integración (SDD 7.1) --------------------
# Clave maestra AES-256-GCM con la que se cifran las credenciales de cada agente.
# 32 bytes en base64. Generar con: openssl rand -base64 32
#
# IMPORTANTE: rotarla obliga a re-cifrar todas las filas. Generala una sola vez y
# guardala también fuera de Vercel (gestor de contraseñas del equipo).
# Se usa a partir del sprint 2, cuando el admin interno da de alta agentes.
ENCRYPTION_KEY=

# --- Email (recuperación de contraseña) ----------------------------------
# Sin RESEND_API_KEY, en desarrollo el link se imprime en la consola del servidor
# en vez de enviarse. En producción, su ausencia es un error.
RESEND_API_KEY=

# Remitente verificado en Resend, ej. "Vibo <no-reply@vibo.ar>"
EMAIL_FROM=

# --- Cron de Vercel (SDD 9.5) --------------------------------------------
# Secreto con el que se valida que /api/cron/ciclo lo llame Vercel Cron y no
# cualquiera. Vercel lo manda en el header Authorization: Bearer <CRON_SECRET>.
# Generar como cualquier secreto: openssl rand -base64 32
# En dev se puede dejar vacío (la ruta se permite sin secreto solo fuera de prod).
CRON_SECRET=

# --- Solo desarrollo: simuladores de integraciones -----------------------
# El SDD (9.3) prohíbe apuntar entornos que no sean producción a la
# infraestructura real de un cliente. Para desarrollar sin tocar Airtable/WhatsApp
# de nadie, se levantan simuladores locales (scripts/airtable-simulado.ts y
# scripts/evolution-simulado.ts).
#
# AIRTABLE_API_URL redirige el cliente de Airtable al simulador. En producción se
# deja vacío: se usa la API real (https://api.airtable.com/v0).
AIRTABLE_API_URL=
#
# La URL de Evolution es por agente (credencial cifrada en la fila), así que no
# hay variable de entorno: para probar el envío manual se apunta el agente al
# simulador desde el admin, o con scripts/probar-integracion.ts.
#
# NOTA: los scripts que importan src/lib/crypto.ts necesitan la condición
# react-server para saltear "server-only":
#   NODE_OPTIONS="--conditions=react-server" npx tsx scripts/<script>.ts
