// Vibo — schema de datos (SDD v1, sección 3)
//
// Todo lo que vive acá es propio de la plataforma. Los turnos NO se modelan:
// siguen viviendo en Airtable (Reservas + Slots), según la decisión del punto 10
// del documento de requerimientos.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  CLIENTE_OWNER // dueño del complejo, login del panel cliente
  VIBO_ADMIN // equipo de Vibo, panel admin interno
}

enum EstadoAgente {
  // El cliente ya puede configurarlo y probarlo en el chat de prueba, pero
  // todavía NO está conectado a WhatsApp real (SDD v2 §2). El paso a ACTIVO es
  // una acción manual del admin, después de cargar y verificar las credenciales.
  // Cuenta contra el límite de agentes del plan: si no, alguien podría tener
  // varios "probándose" indefinidamente sin ocupar lugar.
  EN_CONFIGURACION
  ACTIVO
  PAUSADO_MANUAL // lo pausó el dueño desde la plataforma
  PAUSADO_LIMITE // se pausó solo por llegar al límite de conversaciones del plan
  // Se pausó por falta de pago (SDD v2 §4.4), tras agotarse el período de
  // gracia. A diferencia de PAUSADO_LIMITE, el cron de ciclo NO lo levanta:
  // esto se resuelve cobrando, no esperando al mes siguiente.
  PAUSADO_POR_PAGO
}

// Estado de la suscripción del cliente (SDD v2 §4.2).
enum EstadoPago {
  SIN_SUSCRIPCION // todavía no se le generó la suscripción en Mercado Pago
  AL_DIA
  EN_GRACIA // falló un cobro; hay N días para resolverlo antes de cortar
  VENCIDO // se agotó la gracia: los agentes quedan en PAUSADO_POR_PAGO
}

enum EstadoPagoRegistro {
  APROBADO
  RECHAZADO
  PENDIENTE
}

enum OrigenPago {
  MERCADOPAGO
  MANUAL // transferencia, efectivo o cortesía, cargado a mano desde el admin
}

enum EstadoConversacion {
  ABIERTA
  IA_RESPONDIENDO
  REQUIERE_ATENCION_HUMANA
  CERRADA
}

enum RemitenteMensaje {
  CONTACTO // el cliente final (quien escribe al WhatsApp)
  IA
  HUMANO // el dueño, cuando tomó control manual
}

model Cliente {
  id        String    @id @default(cuid())
  nombre    String
  planId    String
  plan      Plan      @relation(fields: [planId], references: [id])
  usuarios  Usuario[]
  agentes   Agente[]
  createdAt DateTime  @default(now())

  // Facturación (SDD v2 §4). El cliente NO se autosuscribe: la suscripción la
  // genera Vibo en Mercado Pago y le manda el link por fuera de la plataforma.
  // Acá sólo se refleja el resultado que llega por webhook.
  // Archivado: el cliente dejó de serlo, pero su historial se conserva.
  //
  // Es reversible y es el camino normal para dar de baja: borrar de verdad
  // destruiría los pagos (contabilidad) y los mensajes de los clientes finales.
  // Un archivado desaparece de los listados y métricas del admin, y su bot deja
  // de responder — no se le sigue dando servicio a quien ya no es cliente.
  archivadoAt               DateTime?
  // Notas del equipo de Vibo sobre este cliente (SDD v2 §8).
  //
  // **Nunca se le muestran al cliente.** Ninguna consulta de `lib/cliente/*` la
  // selecciona, y por eso este campo no aparece en ningún tipo que cruce al
  // panel del dueño. Es para escribir lo que uno no le diría en la cara: "paga
  // tarde siempre", "lo trajo Fulano", "quiere irse".
  notasInternas             String?    @db.Text
  mercadoPagoSubscriptionId String?
  estadoPago                EstadoPago @default(SIN_SUSCRIPCION)
  fechaProximoCobro         DateTime?
  // Día del mes (1–28) en que se renueva el pozo de conversaciones del cliente
  // (requerimiento de testing: la renovación debe ser un mes post-pago, no el
  // 1° calendario). Se sella con el día del cobro cuando se registra un pago.
  // Null = sin suscripción todavía → el ciclo cae al mes calendario (día 1),
  // que es el comportamiento histórico. Ver [[vibo-sprint-estado]] y `lib/ciclo.ts`.
  cicloDiaAnclaje           Int?
  // Cuándo entró en EN_GRACIA. Es lo que el cron usa para saber si ya se
  // agotaron los días de gracia, y para mandar el recordatorio del medio.
  graciaDesde               DateTime?
  // Hasta dónde se avisó por email, para no repetir el mismo aviso cada día que
  // corre el cron (§4.5 son 3 emails puntuales, no un goteo diario).
  ultimoAvisoPagoEn         DateTime?
  pagos                     Pago[]
}

// Un cobro registrado (SDD v2 §4.2).
//
// Vibo nunca ve datos de tarjeta ni arma el checkout: esto es el resultado que
// informa Mercado Pago por webhook, o una carga manual del admin cuando el
// cliente pagó por transferencia, efectivo o cortesía.
model Pago {
  id          String             @id @default(cuid())
  clienteId   String
  cliente     Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  monto       Decimal            @db.Decimal(12, 2)
  fecha       DateTime
  estado      EstadoPagoRegistro
  origen      OrigenPago
  // El id del pago en Mercado Pago. Único: es lo que hace que reprocesar el
  // mismo webhook —MP reintenta— no cree dos pagos. Null si origen = MANUAL.
  mpPaymentId String?            @unique
  createdAt   DateTime           @default(now())

  @@index([clienteId, fecha])
}

model Usuario {
  id           String               @id @default(cuid())
  email        String               @unique
  passwordHash String
  rol          RolUsuario
  clienteId    String? // null si es VIBO_ADMIN
  cliente      Cliente?             @relation(fields: [clienteId], references: [id])
  resetTokens  PasswordResetToken[]
  // Se actualiza en cada login exitoso (SDD v2 §6). Alimenta la señal de riesgo
  // del §7: un cliente que hace semanas que no entra al panel es un candidato a
  // churn, y eso se ve antes de que avise.
  ultimoAccesoAt DateTime?
  createdAt    DateTime             @default(now())
}

// Recuperación de contraseña (SDD sección 6.1): link de un solo uso.
// Se guarda el hash del token, nunca el token en sí — si se filtra la base,
// las filas no alcanzan para tomar una cuenta.
model PasswordResetToken {
  id        String    @id @default(cuid())
  usuarioId String
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime? // sellado al consumirlo: es lo que garantiza el "un solo uso"
  createdAt DateTime  @default(now())

  @@index([usuarioId])
}

model Plan {
  id                   String    @id @default(cuid())
  nombre               String // "Starter", "Profesional", "Multi-sede"
  maxAgentes           Int
  maxConversacionesMes Int
  clientes             Cliente[]

  // El precio mensual (SDD v2 §4.2). Deja de ser un borrador: Mercado Pago
  // exige un monto real para crear la suscripción.
  //
  // Arranca en 0 porque los planes ya existen en la base y hay que poder
  // migrar sin inventarles un precio. Un plan en 0 es "sin precio definido" y
  // la UI del admin lo marca como pendiente — no se le cobra 0 a nadie.
  precio            Decimal @default(0) @db.Decimal(12, 2)
  // El id del plan de suscripción del lado de Mercado Pago, para poder cruzar
  // lo que llega por webhook con el plan de Vibo.
  mercadoPagoPlanId String?
}

model Agente {
  id         String       @id @default(cuid())
  clienteId  String
  cliente    Cliente      @relation(fields: [clienteId], references: [id])
  nombre     String // nombre del agente/sede, ej. "Club Chinda Fútbol 5"
  deporte    String
  // Nace EN_CONFIGURACION (SDD v2 §2): que exista la fila no significa que el
  // bot esté atendiendo. Lo pasa a ACTIVO el admin, a mano, recién después de
  // verificar las credenciales reales contra el checklist de alta.
  estado     EstadoAgente @default(EN_CONFIGURACION)
  promptBase String       @db.Text

  // Configuración de negocio que el dueño ve y edita desde la sección Agentes
  // (requerimientos §7). Todos opcionales: no bloquean el funcionamiento del
  // agente y las sedes dadas de alta antes de este cambio no los tienen.
  // OJO: hoy esto se guarda en Vibo pero NO se sincroniza con n8n — el bot sigue
  // usando su prompt de n8n. Sincronizarlo es parte de "conectar el agente real".
  direccion           String? // dirección de la sede
  telefonoContacto    String? // teléfono de contacto del negocio
  tono                String? // tono del agente, ej. "cercano y breve"
  anticipacionMinHoras Int?   // anticipación mínima para reservar, en horas
  politicaCancelacion String? @db.Text // texto libre con la política de cancelación
  senia               String? @db.Text // seña/adelanto si aplica
  faq                 String? @db.Text // preguntas frecuentes / base de conocimiento

  // Credenciales de integraciones — cifradas en reposo con AES-256-GCM (SDD sección 7.1).
  // Van por fila y no en variables de entorno de Vercel porque cada agente tiene su
  // propia base de Airtable y su propia instancia de Evolution API.
  airtableBaseId      String
  airtableApiKeyEnc   String  @db.Text
  evolutionInstanceId String
  evolutionApiUrlEnc  String  @db.Text
  evolutionApiKeyEnc  String  @db.Text
  n8nWorkflowId       String? // referencia informativa, n8n se administra fuera de Vibo

  // Token con el que n8n autentica sus llamadas a /api/integracion/* (SDD sección 6.2).
  // Cifrado igual que el resto de las credenciales. Nullable porque se genera al dar
  // de alta el agente (sprint 2) y recién se consume en el sprint 4.
  tokenIntegracionEnc String? @db.Text

  // Hash SHA-256 del mismo token, para resolver una llamada entrante a su agente
  // por índice. El cifrado con GCM usa IV aleatorio, así que el mismo token da un
  // ciphertext distinto cada vez y no sirve para buscar; el hash sí. Se guardan
  // los dos: el cifrado para el enmascarado del admin, el hash para la búsqueda.
  tokenIntegracionHash String? @unique

  // Salud de la integración (SDD v2 §5). Se sella cuando la capa de Airtable o
  // Evolution agota sus reintentos, para que el admin vea proactivamente qué
  // cliente tiene un problema técnico en vez de enterarse por un reclamo.
  //
  // Guarda sólo el ÚLTIMO error, no un historial: la pregunta que responde es
  // "¿esto está roto ahora?", no "¿qué pasó el mes pasado?".
  ultimoErrorIntegracionAt  DateTime?
  ultimoErrorIntegracionMsg String?

  canchas        Cancha[]
  conversaciones Conversacion[]
  usoMensual     UsoMensual[]
  pruebasUso     PruebaAgenteUso[]
  createdAt      DateTime       @default(now())
}

// Tope diario del chat de prueba, por agente (SDD v2 §3).
//
// El chat de prueba llama a OpenAI con la API key GLOBAL de Vibo: el costo lo
// absorbe Vibo, no el cliente. Sin un tope, un cliente probando en bucle es
// gasto directo nuestro — de ahí que el contador viva en la base y no en memoria.
//
// No tiene nada que ver con UsoMensual: las pruebas NO consumen el plan del
// cliente, porque no son conversaciones reales con nadie.
model PruebaAgenteUso {
  id            String   @id @default(cuid())
  agenteId      String
  agente        Agente   @relation(fields: [agenteId], references: [id], onDelete: Cascade)
  fecha         DateTime // el día, sin hora
  mensajesCount Int      @default(0)

  @@unique([agenteId, fecha])
}

model Cancha {
  id               String  @id @default(cuid())
  agenteId         String
  agente           Agente  @relation(fields: [agenteId], references: [id])
  numero           Int // 1, 2, 3... — el backend arma "Cancha {numero}" para cruzar con Airtable
  // Precio BASE de la cancha: el que se cotiza cuando el turno no cae en ninguna
  // banda horaria. Los `tramos` lo pisan para las franjas que definan.
  precio           Decimal @db.Decimal(12, 2)
  duracionTurnoMin Int
  // "08:00" — el horario de cierre puede ser MENOR al de apertura cuando el
  // complejo cierra pasada la medianoche (ej. abre 18:00, cierra 02:00): el
  // cierre se interpreta como del día siguiente. Ver `lib/canchas.ts`.
  horarioApertura  String
  horarioCierre    String // "23:00" (o "02:00" si cierra de madrugada)
  // Descripción libre de la cancha (requerimiento de testing): superficie,
  // techada/descubierta, iluminación, etc. La ve el dueño y la cotiza el bot.
  descripcion      String? @db.Text

  // Precios diferenciales por franja horaria (requerimiento de testing). Una
  // cancha puede no tener ninguno (cotiza siempre `precio`) o varios. Si el
  // inicio de un turno cae en un tramo, se cobra el precio del tramo.
  tramos TramoPrecio[]

  @@unique([agenteId, numero])
}

// Un precio distinto para una franja horaria de una cancha (requerimiento de
// testing: "distintos precios dependiendo el horario del turno").
//
// El precio de la cancha (`Cancha.precio`) sigue siendo el precio base / de
// fallback; cada tramo lo pisa para su franja. Los tramos NO pueden solaparse
// entre sí (lo valida `lib/canchas.ts`), así que el precio de un horario es
// determinista: como mucho un tramo lo contiene.
model TramoPrecio {
  id       String  @id @default(cuid())
  canchaId String
  cancha   Cancha  @relation(fields: [canchaId], references: [id], onDelete: Cascade)
  desde    String // "18:00" — inicio de la franja, inclusive
  hasta    String // "24:00" — fin de la franja, exclusive ("24:00" = medianoche)
  precio   Decimal @db.Decimal(12, 2)

  @@index([canchaId])
}

model UsoMensual {
  id                  String    @id @default(cuid())
  agenteId            String
  agente              Agente    @relation(fields: [agenteId], references: [id])
  cicloInicio         DateTime
  cicloFin            DateTime
  conversacionesCount Int       @default(0)
  limiteAlcanzadoEn   DateTime?

  @@unique([agenteId, cicloInicio])
}

model Conversacion {
  id               String             @id @default(cuid())
  agenteId         String
  agente           Agente             @relation(fields: [agenteId], references: [id])
  contactoTelefono String
  contactoNombre   String?
  estado           EstadoConversacion @default(ABIERTA)
  pausadaManual    Boolean            @default(false) // la IA no responde en ESTE chat puntual
  ultimoMensajeAt  DateTime
  // Cuándo el dueño vio esta conversación por última vez. Null = nunca la abrió.
  // El filtro "no leídas" (requerimientos punto 9) compara contra ultimoMensajeAt:
  // hay mensajes sin leer si leidaAt es null o quedó antes del último mensaje.
  // El punto 9 lo pide y el modelo del SDD (punto 3) no lo previó.
  leidaAt          DateTime?
  // El cicloInicio para el que esta conversación ya fue contada en el uso del
  // plan (sprint 5). El límite se mide "una vez por conversación nueva en el
  // ciclo" (SDD 4.3): al llegar un mensaje del contacto se compara este campo
  // contra el ciclo actual, y solo si difiere se incrementa el consumo. Guardar
  // el sello acá permite un compare-and-set atómico y O(1), sin recontar
  // mensajes en el camino caliente.
  contadaEnCiclo   DateTime?
  mensajes         Mensaje[]

  // Una sola conversación continua por contacto y agente, como un chat de
  // WhatsApp. Es único (no solo índice) para que el "buscar-o-crear" del
  // registro de mensajes pueda ser un upsert atómico: sin esto, dos mensajes
  // del mismo contacto que llegan casi juntos crearían dos conversaciones.
  @@unique([agenteId, contactoTelefono])
  // Para ordenar la bandeja por actividad reciente sin escanear toda la tabla.
  @@index([agenteId, ultimoMensajeAt])
}

model Mensaje {
  id             String           @id @default(cuid())
  conversacionId String
  conversacion   Conversacion     @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  remitente      RemitenteMensaje
  contenido      String           @db.Text
  evolutionMsgId String? // id del mensaje en Evolution API, para trazabilidad
  createdAt      DateTime         @default(now())

  @@index([conversacionId, createdAt])
}
